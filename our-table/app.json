{
  "expo": {
    "name": "OurTable",
    "slug": "our-table",
    "scheme": "ourtable",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/branding/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/branding/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A0F0A"
    },
    "ios": {
      "bundleIdentifier": "com.ourtable.app",
      "supportsTablet": false
    },
    "android": {
      "package": "com.ourtable.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/adaptive-icon.png",
        "backgroundColor": "#1A1A1A"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow OurTable to use your location to find nearby restaurants."
        }
      ],
      "./plugins/withAndroidShareIntent"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "60fb942a-33f3-4784-bf67-741d083f72dd"
      }
    },
    "owner": "nainuu"
  }
}